<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/home_chip_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top"
            android:orientation="horizontal">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/orderLineImage"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_product_placeholder"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Void.RoundedImage" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/orderLineName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/home_text_primary"
                    android:textSize="14sp"
                    tools:text="Macbook Pro M1" />

                <TextView
                    android:id="@+id/orderLineMeta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/home_text_hint"
                    android:textSize="12sp"
                    tools:text="Silver · Qty 1" />

                <TextView
                    android:id="@+id/orderLineStore"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/home_section_link"
                    android:textSize="12sp"
                    android:visibility="gone"
                    tools:text="Sold by AlfinasStore" />

                <TextView
                    android:id="@+id/orderLinePrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/home_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="$1,203.00" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/orderLineActionButton"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="12dp"
            android:textColor="@color/home_white"
            android:textSize="13sp"
            android:visibility="gone"
            app:backgroundTint="@color/home_balance_background"
            app:cornerRadius="10dp"
            tools:text="Leave a review"
            tools:visibility="visible" />

        <LinearLayout
            android:id="@+id/orderLineReviewDisplay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.06"
                android:text="YOUR REVIEW"
                android:textColor="@color/home_text_hint"
                android:textSize="10sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/orderLineStar1"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginEnd="2dp"
                    android:contentDescription="@null"
                    app:srcCompat="@drawable/ic_star_rounded" />

                <ImageView
                    android:id="@+id/orderLineStar2"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginEnd="2dp"
                    android:contentDescription="@null"
                    app:srcCompat="@drawable/ic_star_rounded" />

                <ImageView
                    android:id="@+id/orderLineStar3"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginEnd="2dp"
                    android:contentDescription="@null"
                    app:srcCompat="@drawable/ic_star_rounded" />

                <ImageView
                    android:id="@+id/orderLineStar4"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginEnd="2dp"
                    android:contentDescription="@null"
                    app:srcCompat="@drawable/ic_star_rounded" />

                <ImageView
                    android:id="@+id/orderLineStar5"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:contentDescription="@null"
                    app:srcCompat="@drawable/ic_star_rounded" />
            </LinearLayout>

            <TextView
                android:id="@+id/orderLineReviewComment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:lineSpacingMultiplier="1.3"
                android:textColor="@color/home_text_primary"
                android:textSize="13sp"
                android:textStyle="italic"
                android:visibility="gone"
                tools:text="“Excellent build quality.”"
                tools:visibility="visible" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
