<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/home_recommendation_item_spacing"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <View
        android:layout_width="@dimen/home_recommendation_thumb_size"
        android:layout_height="@dimen/home_recommendation_thumb_size"
        android:background="@drawable/bg_skeleton" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <View
            android:layout_width="160dp"
            android:layout_height="14dp"
            android:background="@drawable/bg_skeleton" />

        <View
            android:layout_width="100dp"
            android:layout_height="14dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_skeleton" />

        <View
            android:layout_width="140dp"
            android:layout_height="12dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_skeleton" />
    </LinearLayout>
</LinearLayout>
