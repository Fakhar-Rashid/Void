<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_background">

    <LinearLayout
        android:id="@+id/exploreHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/home_screen_padding"
        android:paddingTop="@dimen/home_content_top_padding"
        android:paddingEnd="@dimen/home_screen_padding"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/exploreBackButton"
            android:layout_width="@dimen/home_header_icon_size"
            android:layout_height="@dimen/home_header_icon_size"
            android:background="@android:color/transparent"
            android:contentDescription="@string/explore_cd_back"
            android:padding="@dimen/home_header_icon_padding"
            android:tint="@color/home_text_primary"
            app:srcCompat="@drawable/ic_arrow_back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="@string/explore_title"
            android:textColor="@color/home_text_primary"
            android:textSize="16sp" />

        <com.example.avoid.NotificationBellButton
            android:layout_width="@dimen/home_header_icon_size"
            android:layout_height="@dimen/home_header_icon_size" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/exploreHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/home_screen_padding"
            android:paddingTop="8dp"
            android:paddingEnd="@dimen/home_screen_padding"
            android:paddingBottom="@dimen/home_content_bottom_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/home_search_height"
                android:background="@drawable/bg_home_search"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/home_search_horizontal_padding"
                android:paddingEnd="@dimen/home_search_horizontal_padding">

                <EditText
                    android:id="@+id/exploreSearchInput"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="@string/explore_search_hint"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textColor="@color/home_text_primary"
                    android:textColorHint="@color/home_text_hint"
                    android:textSize="@dimen/home_search_text_size" />

                <ImageView
                    android:layout_width="@dimen/home_search_icon_size"
                    android:layout_height="@dimen/home_search_icon_size"
                    android:contentDescription="@string/home_cd_search"
                    android:tint="@color/home_text_hint"
                    app:srcCompat="@drawable/ic_search" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/home_section_spacing_medium"
                android:fontFamily="sans-serif-black"
                android:text="@string/explore_search_by_category"
                android:textColor="@color/home_text_primary"
                android:textSize="@dimen/home_section_title_size" />

            <include
                android:id="@+id/categoryChips"
                layout="@layout/view_category_chips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/home_section_spacing_large"
                android:fontFamily="sans-serif-black"
                android:text="@string/explore_trending_search"
                android:textColor="@color/home_text_primary"
                android:textSize="@dimen/home_section_title_size" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/trendingSearchGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="8dp"
                app:singleLine="false" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/home_section_spacing_large"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/trendingProductsTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-black"
                    android:text="@string/explore_trending_products"
                    android:textColor="@color/home_text_primary"
                    android:textSize="@dimen/home_section_title_size" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_see_all"
                    android:textColor="@color/home_section_link"
                    android:textSize="@dimen/home_section_link_size" />
            </LinearLayout>

            <TextView
                android:id="@+id/exploreEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:text="@string/explore_no_results"
                android:textColor="@color/home_text_hint"
                android:textSize="14sp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/exploreResultsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/home_recommendation_top_margin"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                tools:itemCount="3"
                tools:listitem="@layout/item_product_list" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
