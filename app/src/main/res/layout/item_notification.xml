<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/notificationRow"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="20dp"
    android:paddingTop="14dp"
    android:paddingEnd="20dp"
    android:paddingBottom="14dp">

    <FrameLayout
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="12dp">

        <ImageView
            android:id="@+id/notificationIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_avatar_circle"
            android:padding="9dp"
            android:tint="@color/home_white"
            tools:srcCompat="@drawable/ic_bell" />

        <View
            android:id="@+id/notificationUnreadDot"
            android:layout_width="9dp"
            android:layout_height="9dp"
            android:layout_gravity="top|end"
            android:background="@drawable/bg_avatar_circle"
            android:backgroundTint="@color/auth_error" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/notificationTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/home_text_primary"
            android:textSize="14sp"
            tools:text="Order packed" />

        <TextView
            android:id="@+id/notificationBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.25"
            android:maxLines="2"
            android:textColor="@color/home_text_secondary"
            android:textSize="12sp"
            tools:text="Macbook Pro M1 has been packed by Alfina's Store." />

        <TextView
            android:id="@+id/notificationTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textColor="@color/home_text_hint"
            android:textSize="11sp"
            tools:text="2 min ago" />
    </LinearLayout>
</LinearLayout>
