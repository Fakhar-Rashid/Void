<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="8dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_color_chip"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="6dp"
    android:paddingTop="6dp"
    android:paddingEnd="12dp"
    android:paddingBottom="6dp">

    <View
        android:id="@+id/colorChipSwatch"
        android:layout_width="22dp"
        android:layout_height="22dp" />

    <TextView
        android:id="@+id/colorChipName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/home_text_primary"
        android:textSize="13sp" />

    <ImageView
        android:id="@+id/colorChipRemove"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginStart="8dp"
        android:clickable="true"
        android:contentDescription="Remove color"
        android:focusable="true"
        android:tint="@color/home_text_hint"
        app:srcCompat="@drawable/ic_close" />
</LinearLayout>
