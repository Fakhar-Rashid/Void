<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_background">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/homeScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/home_screen_padding"
            android:paddingTop="@dimen/home_content_top_padding"
            android:paddingEnd="@dimen/home_screen_padding"
            android:paddingBottom="@dimen/home_content_bottom_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/homeTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-black"
                    android:includeFontPadding="false"
                    android:text="@string/home_welcome_title"
                    android:textColor="@color/home_text_primary"
                    android:textSize="@dimen/home_title_text_size" />

                <ImageButton
                    android:id="@+id/messagesButton"
                    android:layout_width="@dimen/home_header_icon_size"
                    android:layout_height="@dimen/home_header_icon_size"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/home_cd_messages"
                    android:padding="@dimen/home_header_icon_padding"
                    android:tint="@color/home_text_primary"
                    app:srcCompat="@drawable/ic_chat" />

                <ImageButton
                    android:id="@+id/notificationsButton"
                    android:layout_width="@dimen/home_header_icon_size"
                    android:layout_height="@dimen/home_header_icon_size"
                    android:layout_marginStart="@dimen/home_header_icon_spacing"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/home_cd_notifications"
                    android:padding="@dimen/home_header_icon_padding"
                    android:tint="@color/home_text_primary"
                    app:srcCompat="@drawable/ic_bell" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/searchBar"
                android:layout_width="match_parent"
                android:layout_height="@dimen/home_search_height"
                android:layout_marginTop="@dimen/home_section_spacing_small"
                android:background="@drawable/bg_home_search"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/home_search_horizontal_padding"
                android:paddingEnd="@dimen/home_search_horizontal_padding">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/home_search_hint"
                    android:textColor="@color/home_text_hint"
                    android:textSize="@dimen/home_search_text_size" />

                <ImageView
                    android:layout_width="@dimen/home_search_icon_size"
                    android:layout_height="@dimen/home_search_icon_size"
                    android:contentDescription="@string/home_cd_search"
                    android:tint="@color/home_text_hint"
                    app:srcCompat="@drawable/ic_search" />
            </LinearLayout>

            <include
                android:id="@+id/balanceCard"
                layout="@layout/view_balance_card"
                android:layout_width="match_parent"
                android:layout_height="@dimen/home_balance_card_height"
                android:layout_marginTop="@dimen/home_section_spacing_small" />

            <include
                android:id="@+id/categoryChips"
                layout="@layout/view_category_chips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/home_section_spacing_medium" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/home_section_spacing_medium"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="@dimen/home_banner_width"
                        android:layout_height="@dimen/home_banner_height"
                        android:layout_marginEnd="@dimen/home_banner_spacing"
                        android:contentDescription="@null"
                        android:scaleType="centerCrop"
                        android:src="@drawable/banner_1"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Void.RoundedImage" />

                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="@dimen/home_banner_width"
                        android:layout_height="@dimen/home_banner_height"
                        android:contentDescription="@null"
                        android:scaleType="centerCrop"
                        android:src="@drawable/banner_2"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Void.RoundedImage" />
                </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/home_section_spacing_large"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-black"
                    android:text="@string/home_best_sellers"
                    android:textColor="@color/home_text_primary"
                    android:textSize="@dimen/home_section_title_size" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_see_all"
                    android:textColor="@color/home_section_link"
                    android:textSize="@dimen/home_section_link_size" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/bestSellersRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/home_product_cards_top_margin"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                android:paddingEnd="@dimen/home_recycler_end_padding"
                tools:itemCount="3"
                tools:listitem="@layout/item_product_card" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/home_section_spacing_large"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-black"
                    android:text="@string/home_recommendation"
                    android:textColor="@color/home_text_primary"
                    android:textSize="@dimen/home_section_title_size" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_see_all"
                    android:textColor="@color/home_section_link"
                    android:textSize="@dimen/home_section_link_size" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recommendationsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/home_recommendation_top_margin"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                tools:itemCount="2"
                tools:listitem="@layout/item_product_list" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
