<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_background">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/homeScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/home_screen_padding"
            android:paddingTop="@dimen/home_content_top_padding"
            android:paddingEnd="@dimen/home_screen_padding"
            android:paddingBottom="@dimen/home_content_bottom_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/homeTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-black"
                    android:includeFontPadding="false"
                    android:text="@string/home_welcome_title"
                    android:textColor="@color/home_text_primary"
                    android:textSize="@dimen/home_title_text_size" />

                <ImageButton
                    android:id="@+id/messagesButton"
                    android:layout_width="@dimen/home_header_icon_size"
                    android:layout_height="@dimen/home_header_icon_size"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/home_cd_messages"
                    android:padding="@dimen/home_header_icon_padding"
                    android:tint="@color/home_text_primary"
                    app:srcCompat="@drawable/ic_chat" />

                <ImageButton
                    android:id="@+id/notificationsButton"
                    android:layout_width="@dimen/home_header_icon_size"
                    android:layout_height="@dimen/home_header_icon_size"
                    android:layout_marginStart="@dimen/home_header_icon_spacing"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/home_cd_notifications"
                    android:padding="@dimen/home_header_icon_padding"
                    android:tint="@color/home_text_primary"
                    app:srcCompat="@drawable/ic_bell" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/searchBar"
                android:layout_width="match_parent"
                android:layout_height="@dimen/home_search_height"
                android:layout_marginTop="@dimen/home_section_spacing_small"
                android:background="@drawable/bg_home_search"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/home_search_horizontal_padding"
                android:paddingEnd="@dimen/home_search_horizontal_padding">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/home_search_hint"
                    android:textColor="@color/home_text_hint"
                    android:textSize="@dimen/home_search_text_size" />

                <ImageView
                    android:layout_width="@dimen/home_search_icon_size"
                    android:layout_height="@dimen/home_search_icon_size"
                    android:contentDescription="@string/home_cd_search"
                    android:tint="@color/home_text_hint"
                    app:srcCompat="@drawable/ic_search" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/balanceCard"
                android:layout_width="match_parent"
                android:layout_height="@dimen/home_balance_card_height"
                android:layout_marginTop="@dimen/home_section_spacing_small"
                android:background="@drawable/bg_balance_card"
                android:elevation="@dimen/home_card_elevation"
                android:padding="@dimen/home_balance_card_padding">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <TextView
                        android:id="@+id/balanceLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_balance_label"
                        android:textColor="@color/home_balance_label"
                        android:textSize="@dimen/home_balance_label_size"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/balanceAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/home_balance_amount_top_margin"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/home_balance_amount"
                        android:textColor="@color/home_white"
                        android:textSize="@dimen/home_balance_amount_size"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/balanceLabel" />

                    <LinearLayout
                        android:id="@+id/topUpButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_top_up_button"
                        android:gravity="center"
                        android:minHeight="@dimen/home_top_up_height"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/home_top_up_horizontal_padding"
                        android:paddingTop="@dimen/home_top_up_vertical_padding"
                        android:paddingEnd="@dimen/home_top_up_horizontal_padding"
                        android:paddingBottom="@dimen/home_top_up_vertical_padding"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/home_top_up_plus_spacing"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/home_plus_symbol"
                            android:textColor="@color/home_white"
                            android:textSize="@dimen/home_top_up_plus_size" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_top_up"
                            android:textColor="@color/home_white"
                            android:textSize="@dimen/home_top_up_text_size" />
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </FrameLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/home_section_spacing_medium"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/home_chip_height"
                        android:background="@drawable/bg_category_chip"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/home_chip_horizontal_padding"
                        android:paddingEnd="@dimen/home_chip_horizontal_padding">

                        <ImageView
                            android:layout_width="@dimen/home_chip_icon_size"
                            android:layout_height="@dimen/home_chip_icon_size"
                            android:contentDescription="@string/home_cd_laptop"
                            android:tint="@color/home_chip_text"
                            app:srcCompat="@drawable/ic_laptop" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/home_chip_text_spacing"
                            android:text="@string/home_category_laptop"
                            android:textColor="@color/home_chip_text"
                            android:textSize="@dimen/home_chip_text_size" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/home_chip_height"
                        android:layout_marginStart="@dimen/home_chip_spacing"
                        android:background="@drawable/bg_category_chip"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/home_chip_horizontal_padding"
                        android:paddingEnd="@dimen/home_chip_horizontal_padding">

                        <ImageView
                            android:layout_width="@dimen/home_chip_icon_size"
                            android:layout_height="@dimen/home_chip_icon_size"
                            android:contentDescription="@string/home_cd_smartphone"
                            android:tint="@color/home_chip_text"
                            app:srcCompat="@drawable/ic_smartphone" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/home_chip_text_spacing"
                            android:text="@string/home_category_smartphone"
                            android:textColor="@color/home_chip_text"
                            android:textSize="@dimen/home_chip_text_size" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/home_chip_height"
                        android:layout_marginStart="@dimen/home_chip_spacing"
                        android:background="@drawable/bg_category_chip"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/home_chip_horizontal_padding"
                        android:paddingEnd="@dimen/home_chip_horizontal_padding">

                        <ImageView
                            android:layout_width="@dimen/home_chip_icon_size"
                            android:layout_height="@dimen/home_chip_icon_size"
                            android:contentDescription="@string/home_cd_monitor"
                            android:tint="@color/home_chip_text"
                            app:srcCompat="@drawable/ic_monitor" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/home_chip_text_spacing"
                            android:text="@string/home_category_monitor"
                            android:textColor="@color/home_chip_text"
                            android:textSize="@dimen/home_chip_text_size" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/home_chip_height"
                        android:layout_marginStart="@dimen/home_chip_spacing"
                        android:background="@drawable/bg_category_chip"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/home_chip_horizontal_padding"
                        android:paddingEnd="@dimen/home_chip_horizontal_padding">

                        <ImageView
                            android:layout_width="@dimen/home_chip_icon_size"
                            android:layout_height="@dimen/home_chip_icon_size"
                            android:contentDescription="@string/home_cd_laptop"
                            android:tint="@color/home_chip_text"
                            app:srcCompat="@drawable/ic_laptop" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/home_chip_text_spacing"
                            android:text="@string/home_category_accessories"
                            android:textColor="@color/home_chip_text"
                            android:textSize="@dimen/home_chip_text_size" />
                    </LinearLayout>
                </LinearLayout>
            </HorizontalScrollView>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/home_section_spacing_medium"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="@dimen/home_banner_width"
                        android:layout_height="@dimen/home_banner_height"
                        android:background="@drawable/bg_banner_primary">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="@dimen/home_banner_padding">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:gravity="center_vertical"
                                android:orientation="vertical">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="sans-serif-medium"
                                        android:text="@string/home_promo_network"
                                        android:textColor="@color/home_white"
                                        android:textSize="@dimen/home_banner_network_size" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="@dimen/home_banner_badge_spacing"
                                        android:background="@drawable/bg_banner_badge"
                                        android:paddingStart="@dimen/home_banner_badge_horizontal_padding"
                                        android:paddingTop="@dimen/home_banner_badge_vertical_padding"
                                        android:paddingEnd="@dimen/home_banner_badge_horizontal_padding"
                                        android:paddingBottom="@dimen/home_banner_badge_vertical_padding"
                                        android:text="@string/home_promo_speed"
                                        android:textColor="@color/home_white"
                                        android:textSize="@dimen/home_banner_badge_text_size" />
                                </LinearLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/home_banner_caption_spacing"
                                    android:text="@string/home_promo_caption"
                                    android:textColor="@color/home_promo_caption"
                                    android:textSize="@dimen/home_banner_caption_size" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/home_promo_discount_label"
                                    android:textColor="@color/home_promo_discount"
                                    android:textSize="@dimen/home_banner_discount_label_size" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/home_banner_discount_top_margin"
                                    android:fontFamily="sans-serif-medium"
                                    android:text="@string/home_promo_discount_amount"
                                    android:textColor="@color/home_white"
                                    android:textSize="@dimen/home_banner_discount_amount_size" />
                            </LinearLayout>
                        </LinearLayout>
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="@dimen/home_banner_width"
                        android:layout_height="@dimen/home_banner_height"
                        android:layout_marginStart="@dimen/home_banner_spacing"
                        android:background="@drawable/bg_banner_secondary">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="@dimen/home_banner_padding">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/home_secondary_banner_title"
                                android:textColor="@color/home_white"
                                android:textSize="@dimen/home_secondary_banner_title_size" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/home_secondary_banner_subtitle_top_margin"
                                android:text="@string/home_secondary_banner_subtitle"
                                android:textColor="@color/home_white"
                                android:textSize="@dimen/home_secondary_banner_subtitle_size" />
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/home_section_spacing_large"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-black"
                    android:text="@string/home_best_sellers"
                    android:textColor="@color/home_text_primary"
                    android:textSize="@dimen/home_section_title_size" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_see_all"
                    android:textColor="@color/home_section_link"
                    android:textSize="@dimen/home_section_link_size" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/bestSellersRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/home_product_cards_top_margin"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                android:paddingEnd="@dimen/home_recycler_end_padding"
                tools:itemCount="3"
                tools:listitem="@layout/item_product_card" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/home_section_spacing_large"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-black"
                    android:text="@string/home_recommendation"
                    android:textColor="@color/home_text_primary"
                    android:textSize="@dimen/home_section_title_size" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_see_all"
                    android:textColor="@color/home_section_link"
                    android:textSize="@dimen/home_section_link_size" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recommendationsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/home_recommendation_top_margin"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                tools:itemCount="2"
                tools:listitem="@layout/item_product_list" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
