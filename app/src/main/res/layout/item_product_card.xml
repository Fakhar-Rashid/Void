<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/home_product_card_width"
    android:layout_height="wrap_content"
    android:layout_marginEnd="@dimen/home_product_card_spacing"
    android:orientation="vertical">

    <View
        android:id="@+id/productImagePlaceholder"
        android:layout_width="match_parent"
        android:layout_height="@dimen/home_product_image_height"
        android:background="@drawable/bg_product_placeholder" />

    <TextView
        android:id="@+id/productNameTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/home_product_title_top_margin"
        android:textColor="@color/home_text_secondary"
        android:textSize="@dimen/home_product_name_size" />

    <TextView
        android:id="@+id/productPriceTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/home_product_price_top_margin"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/home_text_primary"
        android:textSize="@dimen/home_product_price_size" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/home_product_meta_top_margin"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="@dimen/home_meta_icon_size"
            android:layout_height="@dimen/home_meta_icon_size"
            android:contentDescription="@string/home_cd_location"
            android:tint="@color/home_text_hint"
            app:srcCompat="@drawable/ic_location" />

        <TextView
            android:id="@+id/productLocationTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/home_meta_text_spacing"
            android:textColor="@color/home_text_hint"
            android:textSize="@dimen/home_meta_text_size" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/home_rating_top_margin"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="@dimen/home_meta_icon_size"
            android:layout_height="@dimen/home_meta_icon_size"
            android:contentDescription="@string/home_cd_rating"
            android:tint="@color/home_rating_star"
            app:srcCompat="@drawable/ic_star" />

        <TextView
            android:id="@+id/productRatingTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/home_meta_text_spacing"
            android:textColor="@color/home_text_hint"
            android:textSize="@dimen/home_meta_text_size" />
    </LinearLayout>
</LinearLayout>
