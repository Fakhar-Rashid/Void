<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="top"
    android:orientation="horizontal"
    android:paddingBottom="12dp"
    android:paddingTop="12dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/cartProductImage"
        android:layout_width="76dp"
        android:layout_height="76dp"
        android:background="@drawable/bg_product_placeholder"
        android:contentDescription="Product"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Void.RoundedImage" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/cartProductName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/home_text_primary"
                android:textSize="14sp" />

            <ImageButton
                android:id="@+id/btnDeleteProduct"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Delete"
                android:padding="4dp"
                android:scaleType="center"
                android:src="@drawable/ic_delete"
                android:tint="@color/cart_delete" />
        </LinearLayout>

        <TextView
            android:id="@+id/cartProductColor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/home_text_hint"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/cartProductPrice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                android:textColor="@color/home_text_primary"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/btnDecreaseQty"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_qty_button"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:text="&#x2212;"
                android:textColor="@color/home_text_primary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/cartProductQty"
                android:layout_width="32dp"
                android:layout_height="28dp"
                android:layout_marginEnd="4dp"
                android:layout_marginStart="4dp"
                android:gravity="center"
                android:textColor="@color/home_text_primary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btnIncreaseQty"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_qty_button"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:text="+"
                android:textColor="@color/home_text_primary"
                android:textSize="16sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
