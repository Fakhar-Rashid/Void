<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_background"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/profileScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp">

            <!-- Avatar + Name -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingBottom="4dp">

                <FrameLayout
                    android:layout_width="84dp"
                    android:layout_height="84dp">

                    <TextView
                        android:id="@+id/profileAvatarInitials"
                        android:layout_width="84dp"
                        android:layout_height="84dp"
                        android:background="@drawable/bg_avatar"
                        android:gravity="center"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/home_white"
                        android:textSize="28sp"
                        tools:text="FR" />

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/bg_avatar_edit"
                        android:contentDescription="Edit avatar"
                        android:padding="5dp"
                        android:tint="@color/home_white"
                        app:srcCompat="@drawable/ic_edit" />
                </FrameLayout>

                <TextView
                    android:id="@+id/profileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="@color/home_text_primary"
                    android:textSize="20sp"
                    tools:text="Fakhar Rashid" />

                <TextView
                    android:id="@+id/profileEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/home_text_hint"
                    android:textSize="14sp"
                    tools:text="rbashir6666@gmail.com" />
            </LinearLayout>

            <include
                android:id="@+id/profileBalanceCard"
                layout="@layout/view_balance_card"
                android:layout_width="match_parent"
                android:layout_height="@dimen/home_balance_card_height"
                android:layout_marginTop="24dp" />

            <!-- ACCOUNT Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="10dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:text="ACCOUNT"
                android:textColor="@color/home_text_hint"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_profile_section"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <!-- Edit Profile -->
                <LinearLayout
                    android:id="@+id/profileEditProfileRow"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="Edit profile"
                        android:tint="@color/home_text_secondary"
                        app:srcCompat="@drawable/ic_edit" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:text="Edit Profile"
                        android:textColor="@color/home_text_primary"
                        android:textSize="15sp" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="Go"
                        android:tint="@color/home_text_hint"
                        app:srcCompat="@drawable/ic_chevron_right" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/home_chip_border" />

                <!-- Edit Address -->
                <LinearLayout
                    android:id="@+id/profileEditAddressRow"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="Edit address"
                        android:tint="@color/home_text_secondary"
                        app:srcCompat="@drawable/ic_map_pin" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:text="Edit Address"
                        android:textColor="@color/home_text_primary"
                        android:textSize="15sp" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="Go"
                        android:tint="@color/home_text_hint"
                        app:srcCompat="@drawable/ic_chevron_right" />
                </LinearLayout>

            </LinearLayout>

            <!-- PREFERENCES Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:text="PREFERENCES"
                android:textColor="@color/home_text_hint"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_profile_section"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <LinearLayout
                    android:id="@+id/profileSettingsRow"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="Settings"
                        android:tint="@color/home_text_secondary"
                        app:srcCompat="@drawable/ic_bell" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:text="Settings"
                        android:textColor="@color/home_text_primary"
                        android:textSize="15sp" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="Go"
                        android:tint="@color/home_text_hint"
                        app:srcCompat="@drawable/ic_chevron_right" />
                </LinearLayout>
            </LinearLayout>

            <!-- SUPPORT Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:text="SUPPORT"
                android:textColor="@color/home_text_hint"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_profile_section"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">


                <!-- Privacy Policy -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="Privacy"
                        android:tint="@color/home_text_secondary"
                        app:srcCompat="@drawable/ic_shield" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:text="Privacy Policy"
                        android:textColor="@color/home_text_primary"
                        android:textSize="15sp" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="Go"
                        android:tint="@color/home_text_hint"
                        app:srcCompat="@drawable/ic_chevron_right" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/home_chip_border" />

                <!-- About -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="About"
                        android:tint="@color/home_text_secondary"
                        app:srcCompat="@drawable/ic_info" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:text="About"
                        android:textColor="@color/home_text_primary"
                        android:textSize="15sp" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="Go"
                        android:tint="@color/home_text_hint"
                        app:srcCompat="@drawable/ic_chevron_right" />
                </LinearLayout>
            </LinearLayout>

            <!-- Log Out row -->
            <LinearLayout
                android:id="@+id/profileLogoutRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_profile_section"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="Log out"
                    android:tint="@color/profile_logout"
                    app:srcCompat="@drawable/ic_logout" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:text="Log Out"
                    android:textColor="@color/profile_logout"
                    android:textSize="15sp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Guest empty state -->
    <LinearLayout
        android:id="@+id/profileGuestContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginBottom="20dp"
            android:contentDescription="Profile"
            android:tint="@color/home_text_hint"
            app:srcCompat="@drawable/ic_profile" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:gravity="center"
            android:text="@string/profile_login_title"
            android:textColor="@color/home_text_primary"
            android:textSize="20sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.3"
            android:text="@string/profile_login_body"
            android:textColor="@color/home_text_hint"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/profileGuestLoginButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/auth_login"
            android:textColor="@color/home_white"
            android:textSize="15sp"
            app:backgroundTint="@color/home_balance_background"
            app:cornerRadius="12dp" />
    </LinearLayout>

    <!-- Fixed bottom: Become a Seller -->
    <LinearLayout
        android:id="@+id/profileBottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/home_background"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="12dp"
        android:paddingEnd="24dp"
        android:paddingBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/profileBecomeSellerButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:fontFamily="sans-serif-medium"
            android:text="Become a Seller"
            android:textColor="@color/home_white"
            android:textSize="15sp"
            app:backgroundTint="@color/home_balance_background"
            app:cornerRadius="12dp" />
    </LinearLayout>

</LinearLayout>
