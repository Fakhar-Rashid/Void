<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Void" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:statusBarColor">@color/home_background</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:forceDarkAllowed">false</item>
    </style>

    <style name="Theme.Void" parent="Base.Theme.Void" />

    <style name="ShapeAppearance.Void.RoundedImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">10dp</item>
    </style>

    <style name="AddProductSectionLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">24dp</item>
        <item name="android:layout_marginBottom">10dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textColor">@color/home_text_hint</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="Theme.Void.Auth" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:statusBarColor">@color/auth_bg</item>
        <item name="android:navigationBarColor">@color/auth_bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:windowBackground">@color/auth_bg</item>
    </style>
</resources>
