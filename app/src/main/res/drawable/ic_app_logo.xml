<?xml version="1.0" encoding="utf-8"?>
<!--
  Single-vector app launcher icon. Black square background + chunky white V.
  Used by AndroidManifest's android:icon / android:roundIcon directly so the icon
  is the same on every Android version (no fall-through to the legacy mipmap PNGs
  that ship with the project template).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path
        android:fillColor="#000000"
        android:pathData="M0,0h108v108H0z" />

    <path
        android:pathData="M38,38 L54,76 L70,38"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:strokeWidth="11" />
</vector>
